rules_version = "2";

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /scenarios/{scenarioId} {
      allow read: if true;
      allow write: if false;
    }

    match /guideProfiles/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /appMetadata/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow list: if false;

      match /sessions/{sessionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.keys().hasAll(["scenarioId", "guideLevel", "device", "startedAt"]);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);

        match /events/{eventId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.sessionId == sessionId;
          allow update: if isOwner(userId);
          allow delete: if isOwner(userId);
        }
      }

      match /feedback/{feedbackId} {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
